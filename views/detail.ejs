<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= coin.name %> Price — CryptoLens</title>
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
</head>
<body>

  <div class="grid-bg" aria-hidden="true"></div>

  <header class="site-header">
    <div class="header-inner">
      <a class="logo" href="/">
        <span class="logo-icon">◈</span>
        <span class="logo-text">CryptoLens</span>
      </a>
      <form class="search-bar" action="/search" method="POST">
        <input type="text" name="symbol" placeholder="Search symbol…" autocomplete="off" spellcheck="false" />
        <button type="submit">LOOKUP →</button>
      </form>
    </div>
  </header>

  <main class="detail-main">

    <a class="back-link" href="/">← Back to Market</a>

    <div class="detail-hero">
      <div class="detail-icon"><%= coin.icon %></div>
      <div class="detail-title-block">
        <h1><%= coin.name %></h1>
        <div class="detail-symbol-tag"><%= coin.symbol %></div>
      </div>
    </div>

    <!-- ── Primary Price ── -->
    <div class="price-card-big">
      <div class="price-label">LAST TRADE PRICE</div>
      <div class="price-big">
        $<%= Number(ticker.last_trade_price).toLocaleString("en-US", { minimumFractionDigits: 2, maximumFractionDigits: 6 }) %>
      </div>
      <div class="price-change-big <%= (ticker.price_24h >= 0) ? 'positive' : 'negative' %>">
        <%= ticker.price_24h >= 0 ? '▲' : '▼' %> <%= Math.abs(Number(ticker.price_24h || 0)).toFixed(4) %>% (24h)
      </div>
    </div>

    <!-- ── Stats Grid ── -->
    <div class="stats-grid">

      <div class="stat-card">
        <div class="stat-label">24H HIGH</div>
        <div class="stat-value">
          $<%= ticker.price_24h_high ? Number(ticker.price_24h_high).toLocaleString("en-US", { minimumFractionDigits: 2, maximumFractionDigits: 4 }) : "—" %>
        </div>
      </div>

      <div class="stat-card">
        <div class="stat-label">24H LOW</div>
        <div class="stat-value">
          $<%= ticker.price_24h_low ? Number(ticker.price_24h_low).toLocaleString("en-US", { minimumFractionDigits: 2, maximumFractionDigits: 4 }) : "—" %>
        </div>
      </div>

      <div class="stat-card">
        <div class="stat-label">24H VOLUME</div>
        <div class="stat-value">
          <%= ticker.volume_24h ? Number(ticker.volume_24h).toLocaleString("en-US", { maximumFractionDigits: 2 }) : "—" %>
        </div>
      </div>

      <div class="stat-card">
        <div class="stat-label">BEST BID</div>
        <div class="stat-value">
          $<%= ticker.price_24h_open ? Number(ticker.price_24h_open).toLocaleString("en-US", { minimumFractionDigits: 2, maximumFractionDigits: 4 }) : "—" %>
        </div>
      </div>

    </div>

    <!-- ── Raw API Response ── -->
    <div class="raw-block">
      <div class="raw-header">
        <span class="raw-badge">API RESPONSE</span>
        <span class="raw-endpoint">GET /tickers/<%= coin.symbol %></span>
      </div>
      <pre class="raw-json"><%= JSON.stringify(ticker, null, 2) %></pre>
    </div>

    <!-- ── Timestamp ── -->
    <div class="fetch-time">
      Data fetched at: <strong><%= new Date().toUTCString() %></strong>
    </div>

  </main>

  <footer class="site-footer">
    <span>CryptoLens · Built with <strong>Node.js + Express + Axios</strong> · Data from <strong>Blockchain.com</strong></span>
  </footer>

</body>
</html>
